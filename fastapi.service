[Unit]
Description=FastAPI Uvicorn Instance
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/app/src
EnvironmentFile=/home/ubuntu/app/src/.env
ExecStart=/home/ubuntu/app/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always

[Install]
WantedBy=multi-user.target
